{
  "manifest_version": 3,
  "name": "AI Memory Agent",
  "version": "1.0",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "https://claude.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}